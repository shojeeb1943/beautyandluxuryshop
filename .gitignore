# --- LARAVEL STORAGE RULES ---
# 1. Ignore all keys and sensitive framework files
/storage/*.key

# 2. Ignore everything in storage by default
/storage/*

# 3. Allow specific directories (keeps them on GitHub so they exist on cPanel)
!/storage/app/public/
!/storage/framework/views/
!/storage/logs/

# 4. Optional: If you want to ensure the folders exist but remain empty of files
# uncomment the lines below:
/storage/app/public/*
# /storage/logs/*